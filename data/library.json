  "constraints": [
    {
      "id": "c1",
      "type": "recommendation",
      "if": {
        "slot": "ZIEL_TYP",
        "equals": "entscheidung_vorbereiten"
      },
      "then": {
        "recommended_slots": ["FORMAT", "ERGEBNISORIENTIERUNG", "PROZESSLOGIK"],
        "recommended_values": {
          "FORMAT": ["tabelle", "liste"],
          "ERGEBNISORIENTIERUNG": ["ergebnis_plus_begruendung", "ergebnis_plus_naechste_schritte"]
        }
      }
    },
    {
      "id": "c2",
      "type": "recommendation",
      "if": {
        "slot": "ZIEL_TYP",
        "equals": "umformulieren"
      },
      "then": {
        "recommended_slots": ["SPRACHQUALITAET", "INHALTLICHE_AUSSCHLUESSE", "FORMAT"],
        "recommended_values": {
          "FORMAT": ["fliesstext", "liste"]
        }
      }
    },
    {
      "id": "c3",
      "type": "incompatibility",
      "if": {
        "slot": "FORMAT",
        "equals": "tabelle"
      },
      "then_not": {
        "slot": "FORMALE_AUSSCHLUESSE",
        "contains": "keine_tabellen"
      }
    },
    {
      "id": "c4",
      "type": "incompatibility",
      "if": {
        "slot": "FORMAT",
        "equals": "liste"
      },
      "then_not": {
        "slot": "FORMALE_AUSSCHLUESSE",
        "contains": "keine_listen"
      }
    }
  ],
