{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/prompt-library.schema.json",
  "title": "Prompt Library Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "library",
    "slot_schema",
    "templates",
    "constraints",
    "example_instances"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "version",
        "author",
        "created",
        "locale",
        "description"
      ],
      "properties": {
        "project": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "author": { "type": "string", "minLength": 1 },
        "created": { "type": "string", "minLength": 1 },
        "locale": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "library": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/definitions/dimension"
      }
    },
    "slot_schema": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/slotSchemaItem"
      }
    },
    "templates": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/template"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/constraint"
      }
    },
    "example_instances": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/exampleInstance"
      }
    }
  },
  "definitions": {
    "valueItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "description"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "subdimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "slot", "required", "values"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "slot": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "multi": { "type": "boolean" },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/valueItem"
          }
        }
      }
    },
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "description", "subdimensions"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "subdimensions": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/definitions/subdimension"
          }
        }
      }
    },
    "slotSchemaItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slot", "dimension", "subdimension", "required", "multi"],
      "properties": {
        "slot": { "type": "string", "minLength": 1 },
        "dimension": { "type": "string", "minLength": 1 },
        "subdimension": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "multi": { "type": "boolean" }
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "description", "slots_used", "text"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "slots_used": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "text": { "type": "string", "minLength": 1 }
      }
    },
    "constraintIf": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slot", "equals"],
      "properties": {
        "slot": { "type": "string", "minLength": 1 },
        "equals": { "type": "string", "minLength": 1 }
      }
    },
    "constraintThenNot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slot", "contains"],
      "properties": {
        "slot": { "type": "string", "minLength": 1 },
        "contains": { "type": "string", "minLength": 1 }
      }
    },
    "constraintThen": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recommended_slots", "recommended_values"],
      "properties": {
        "recommended_slots": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "recommended_values": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "if"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["recommendation", "incompatibility"]
        },
        "if": {
          "$ref": "#/definitions/constraintIf"
        },
        "then": {
          "$ref": "#/definitions/constraintThen"
        },
        "then_not": {
          "$ref": "#/definitions/constraintThenNot"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "recommendation" } }
          },
          "then": {
            "required": ["then"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "incompatibility" } }
          },
          "then": {
            "required": ["then_not"]
          }
        }
      ]
    },
    "exampleInstance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "values"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "values": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "anyOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          }
        }
      }
    }
  }
}