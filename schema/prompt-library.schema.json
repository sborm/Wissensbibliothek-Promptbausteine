{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sborm.github.io/Wissensbibliothek-Promptbausteine/schema/library.schema.json",
  "title": "Prompt Library Canonical Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "dimensions", "slots", "values", "templates", "generator", "workflows", "heuristics"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project", "version", "author", "locale", "description", "model_principles"],
      "properties": {
        "project": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "author": {"type": "string", "minLength": 1},
        "locale": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "model_principles": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "key", "label", "description", "slot_order"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "key": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
          "label": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "slot_order": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
            "minItems": 1,
            "uniqueItems": true
          }
        }
      }
    },
    "slots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "key", "label", "dimension", "required", "multi", "value_set", "description"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "key": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
          "label": {"type": "string", "minLength": 1},
          "dimension": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
          "required": {"type": "boolean"},
          "multi": {"const": false},
          "value_set": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "description": {"type": "string", "minLength": 1}
        }
      }
    },
    "values": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["key", "label"],
          "properties": {
            "key": {"type": "string", "pattern": "^[a-z0-9_]+$"},
            "label": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "description", "slots_used", "text"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "slots_used": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
            "minItems": 1,
            "uniqueItems": true
          },
          "text": {"type": "string", "minLength": 1}
        }
      }
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_template_id", "slot_sequence", "required_slots", "modes", "copy_behavior", "empty_value_behavior"],
      "properties": {
        "default_template_id": {"type": "string", "minLength": 1},
        "slot_sequence": {"type": "array", "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"}, "minItems": 1, "uniqueItems": true},
        "required_slots": {"type": "array", "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"}, "minItems": 1, "uniqueItems": true},
        "modes": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true},
        "copy_behavior": {"type": "string", "minLength": 1},
        "empty_value_behavior": {"type": "string", "minLength": 1}
      }
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "template_id", "values"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "template_id": {"type": "string", "minLength": 1},
          "values": {
            "type": "object",
            "propertyNames": {"pattern": "^[A-Z0-9_]+$"},
            "additionalProperties": {"type": "string", "pattern": "^[a-z0-9_]+$"},
            "minProperties": 1
          }
        }
      }
    },
    "heuristics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "description", "recommendations", "constraints", "meta"],
      "properties": {
        "enabled": {"type": "boolean"},
        "description": {"type": "string", "minLength": 1},
        "recommendations": {"type": "array"},
        "constraints": {"type": "array"},
        "meta": {"type": "object"}
      }
    }
  }
}
