{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sborm.github.io/Wissensbibliothek-Promptbausteine/schema/library.schema.json",
  "title": "Prompt Library Schema",
  "description": "Schema fuer das kanonische Zielmodell der Prompt-Bibliothek mit single-select Taxonomie, Generator-Layer und optionalem Heuristik-Layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "dimensions",
    "slots",
    "values",
    "templates",
    "generator",
    "workflows",
    "heuristics"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "version",
        "author",
        "locale",
        "description",
        "model_principles"
      ],
      "properties": {
        "project": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "locale": {
          "type": "string",
          "pattern": "^[a-z]{2}-[A-Z]{2}$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "model_principles": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "dimensions": {
      "type": "array",
      "minItems": 8,
      "items": {
        "$ref": "#/$defs/dimension"
      }
    },
    "slots": {
      "type": "array",
      "minItems": 28,
      "items": {
        "$ref": "#/$defs/slot"
      }
    },
    "values": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ziel_typ",
        "ziel_reife",
        "aufgabentyp",
        "aufgabenstruktur",
        "situationskontext",
        "zielgruppe",
        "wissensniveau",
        "rahmenbedingung",
        "prozesslogik",
        "methodik",
        "interaktionsmodus",
        "steuerungsgrad",
        "arbeitsmodus",
        "format",
        "umfang",
        "ergebnisfokus",
        "tonalitaet",
        "direktheit",
        "rollenstimme",
        "qualitaetsfokus",
        "priorisierung",
        "tiefengrad",
        "evidenzregel",
        "tabellenregel",
        "listenregel",
        "beispielregel",
        "metaregel",
        "redundanzregel"
      ],
      "properties": {
        "ziel_typ": {
          "$ref": "#/$defs/valueSet"
        },
        "ziel_reife": {
          "$ref": "#/$defs/valueSet"
        },
        "aufgabentyp": {
          "$ref": "#/$defs/valueSet"
        },
        "aufgabenstruktur": {
          "$ref": "#/$defs/valueSet"
        },
        "situationskontext": {
          "$ref": "#/$defs/valueSet"
        },
        "zielgruppe": {
          "$ref": "#/$defs/valueSet"
        },
        "wissensniveau": {
          "$ref": "#/$defs/valueSet"
        },
        "rahmenbedingung": {
          "$ref": "#/$defs/valueSet"
        },
        "prozesslogik": {
          "$ref": "#/$defs/valueSet"
        },
        "methodik": {
          "$ref": "#/$defs/valueSet"
        },
        "interaktionsmodus": {
          "$ref": "#/$defs/valueSet"
        },
        "steuerungsgrad": {
          "$ref": "#/$defs/valueSet"
        },
        "arbeitsmodus": {
          "$ref": "#/$defs/valueSet"
        },
        "format": {
          "$ref": "#/$defs/valueSet"
        },
        "umfang": {
          "$ref": "#/$defs/valueSet"
        },
        "ergebnisfokus": {
          "$ref": "#/$defs/valueSet"
        },
        "tonalitaet": {
          "$ref": "#/$defs/valueSet"
        },
        "direktheit": {
          "$ref": "#/$defs/valueSet"
        },
        "rollenstimme": {
          "$ref": "#/$defs/valueSet"
        },
        "qualitaetsfokus": {
          "$ref": "#/$defs/valueSet"
        },
        "priorisierung": {
          "$ref": "#/$defs/valueSet"
        },
        "tiefengrad": {
          "$ref": "#/$defs/valueSet"
        },
        "evidenzregel": {
          "$ref": "#/$defs/valueSet"
        },
        "tabellenregel": {
          "$ref": "#/$defs/valueSet"
        },
        "listenregel": {
          "$ref": "#/$defs/valueSet"
        },
        "beispielregel": {
          "$ref": "#/$defs/valueSet"
        },
        "metaregel": {
          "$ref": "#/$defs/valueSet"
        },
        "redundanzregel": {
          "$ref": "#/$defs/valueSet"
        }
      }
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/template"
      }
    },
    "generator": {
      "$ref": "#/$defs/generator"
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/workflow"
      }
    },
    "heuristics": {
      "$ref": "#/$defs/heuristics"
    }
  },
  "$defs": {
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "key",
        "label",
        "description",
        "slot_order"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z]$"
        },
        "key": {
          "type": "string",
          "enum": [
            "ZIEL",
            "AUFGABE",
            "KONTEXT",
            "PROZESS",
            "OUTPUT",
            "STIL",
            "KRITERIEN",
            "GRENZEN"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "slot_order": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ZIEL_TYP",
              "ZIEL_REIFE",
              "AUFGABENTYP",
              "AUFGABENSTRUKTUR",
              "SITUATIONSKONTEXT",
              "ZIELGRUPPE",
              "WISSENSNIVEAU",
              "RAHMENBEDINGUNG",
              "PROZESSLOGIK",
              "METHODIK",
              "INTERAKTIONSMODUS",
              "STEUERUNGSGRAD",
              "ARBEITSMODUS",
              "FORMAT",
              "UMFANG",
              "ERGEBNISFOKUS",
              "TONALITAET",
              "DIREKTHEIT",
              "ROLLENSTIMME",
              "QUALITAETSFOKUS",
              "PRIORISIERUNG",
              "TIEFENGRAD",
              "EVIDENZREGEL",
              "TABELLENREGEL",
              "LISTENREGEL",
              "BEISPIELREGEL",
              "METAREGEL",
              "REDUNDANZREGEL"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "slot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "key",
        "label",
        "dimension",
        "required",
        "multi",
        "value_set",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][0-9]+$"
        },
        "key": {
          "type": "string",
          "enum": [
            "ZIEL_TYP",
            "ZIEL_REIFE",
            "AUFGABENTYP",
            "AUFGABENSTRUKTUR",
            "SITUATIONSKONTEXT",
            "ZIELGRUPPE",
            "WISSENSNIVEAU",
            "RAHMENBEDINGUNG",
            "PROZESSLOGIK",
            "METHODIK",
            "INTERAKTIONSMODUS",
            "STEUERUNGSGRAD",
            "ARBEITSMODUS",
            "FORMAT",
            "UMFANG",
            "ERGEBNISFOKUS",
            "TONALITAET",
            "DIREKTHEIT",
            "ROLLENSTIMME",
            "QUALITAETSFOKUS",
            "PRIORISIERUNG",
            "TIEFENGRAD",
            "EVIDENZREGEL",
            "TABELLENREGEL",
            "LISTENREGEL",
            "BEISPIELREGEL",
            "METAREGEL",
            "REDUNDANZREGEL"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "dimension": {
          "type": "string",
          "enum": [
            "ZIEL",
            "AUFGABE",
            "KONTEXT",
            "PROZESS",
            "OUTPUT",
            "STIL",
            "KRITERIEN",
            "GRENZEN"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "multi": {
          "const": false
        },
        "value_set": {
          "type": "string",
          "enum": [
            "ziel_typ",
            "ziel_reife",
            "aufgabentyp",
            "aufgabenstruktur",
            "situationskontext",
            "zielgruppe",
            "wissensniveau",
            "rahmenbedingung",
            "prozesslogik",
            "methodik",
            "interaktionsmodus",
            "steuerungsgrad",
            "arbeitsmodus",
            "format",
            "umfang",
            "ergebnisfokus",
            "tonalitaet",
            "direktheit",
            "rollenstimme",
            "qualitaetsfokus",
            "priorisierung",
            "tiefengrad",
            "evidenzregel",
            "tabellenregel",
            "listenregel",
            "beispielregel",
            "metaregel",
            "redundanzregel"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "valueSet": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/value"
      }
    },
    "value": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "label"
      ],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "description",
        "slots_used",
        "text"
      ],
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "default_v1",
            "analysis_v1",
            "decision_v1",
            "rewrite_v1",
            "implementation_v1"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "slots_used": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ZIEL_TYP",
              "ZIEL_REIFE",
              "AUFGABENTYP",
              "AUFGABENSTRUKTUR",
              "SITUATIONSKONTEXT",
              "ZIELGRUPPE",
              "WISSENSNIVEAU",
              "RAHMENBEDINGUNG",
              "PROZESSLOGIK",
              "METHODIK",
              "INTERAKTIONSMODUS",
              "STEUERUNGSGRAD",
              "ARBEITSMODUS",
              "FORMAT",
              "UMFANG",
              "ERGEBNISFOKUS",
              "TONALITAET",
              "DIREKTHEIT",
              "ROLLENSTIMME",
              "QUALITAETSFOKUS",
              "PRIORISIERUNG",
              "TIEFENGRAD",
              "EVIDENZREGEL",
              "TABELLENREGEL",
              "LISTENREGEL",
              "BEISPIELREGEL",
              "METAREGEL",
              "REDUNDANZREGEL"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_template_id",
        "slot_sequence",
        "required_slots",
        "modes",
        "copy_behavior",
        "empty_value_behavior"
      ],
      "properties": {
        "default_template_id": {
          "type": "string",
          "enum": [
            "default_v1",
            "analysis_v1",
            "decision_v1",
            "rewrite_v1",
            "implementation_v1"
          ]
        },
        "slot_sequence": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ZIEL_TYP",
              "ZIEL_REIFE",
              "AUFGABENTYP",
              "AUFGABENSTRUKTUR",
              "SITUATIONSKONTEXT",
              "ZIELGRUPPE",
              "WISSENSNIVEAU",
              "RAHMENBEDINGUNG",
              "PROZESSLOGIK",
              "METHODIK",
              "INTERAKTIONSMODUS",
              "STEUERUNGSGRAD",
              "ARBEITSMODUS",
              "FORMAT",
              "UMFANG",
              "ERGEBNISFOKUS",
              "TONALITAET",
              "DIREKTHEIT",
              "ROLLENSTIMME",
              "QUALITAETSFOKUS",
              "PRIORISIERUNG",
              "TIEFENGRAD",
              "EVIDENZREGEL",
              "TABELLENREGEL",
              "LISTENREGEL",
              "BEISPIELREGEL",
              "METAREGEL",
              "REDUNDANZREGEL"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "required_slots": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ZIEL_TYP",
              "ZIEL_REIFE",
              "AUFGABENTYP",
              "AUFGABENSTRUKTUR",
              "SITUATIONSKONTEXT",
              "ZIELGRUPPE",
              "WISSENSNIVEAU",
              "RAHMENBEDINGUNG",
              "PROZESSLOGIK",
              "METHODIK",
              "INTERAKTIONSMODUS",
              "STEUERUNGSGRAD",
              "ARBEITSMODUS",
              "FORMAT",
              "UMFANG",
              "ERGEBNISFOKUS",
              "TONALITAET",
              "DIREKTHEIT",
              "ROLLENSTIMME",
              "QUALITAETSFOKUS",
              "PRIORISIERUNG",
              "TIEFENGRAD",
              "EVIDENZREGEL",
              "TABELLENREGEL",
              "LISTENREGEL",
              "BEISPIELREGEL",
              "METAREGEL",
              "REDUNDANZREGEL"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "standard",
              "expert"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "copy_behavior": {
          "type": "string",
          "minLength": 1
        },
        "empty_value_behavior": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "template_id",
        "values"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^workflow_[0-9]{2,}$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "template_id": {
          "type": "string",
          "enum": [
            "default_v1",
            "analysis_v1",
            "decision_v1",
            "rewrite_v1",
            "implementation_v1"
          ]
        },
        "values": {
          "type": "object",
          "propertyNames": {
            "enum": [
              "ZIEL_TYP",
              "ZIEL_REIFE",
              "AUFGABENTYP",
              "AUFGABENSTRUKTUR",
              "SITUATIONSKONTEXT",
              "ZIELGRUPPE",
              "WISSENSNIVEAU",
              "RAHMENBEDINGUNG",
              "PROZESSLOGIK",
              "METHODIK",
              "INTERAKTIONSMODUS",
              "STEUERUNGSGRAD",
              "ARBEITSMODUS",
              "FORMAT",
              "UMFANG",
              "ERGEBNISFOKUS",
              "TONALITAET",
              "DIREKTHEIT",
              "ROLLENSTIMME",
              "QUALITAETSFOKUS",
              "PRIORISIERUNG",
              "TIEFENGRAD",
              "EVIDENZREGEL",
              "TABELLENREGEL",
              "LISTENREGEL",
              "BEISPIELREGEL",
              "METAREGEL",
              "REDUNDANZREGEL"
            ]
          },
          "additionalProperties": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "minProperties": 1
        }
      }
    },
    "heuristics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "description",
        "recommendations",
        "constraints",
        "meta"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "meta": {
          "type": "object"
        }
      }
    }
  }
}