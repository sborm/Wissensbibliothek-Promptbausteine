{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Prompt-Bibliothek V3 Schema",
  "description": "JSON Schema fuer das V3-Zielmodell der Prompt-Bibliothek.",
  "type": "object",
  "required": ["meta", "dimensions", "slots", "values", "templates", "generator", "workflows", "heuristics"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["project", "version", "locale"],
      "properties": {
        "project": {"type": "string"},
        "version": {"type": "string"},
        "author": {"type": "string"},
        "locale": {"type": "string"},
        "description": {"type": "string"},
        "model_principles": {"type": "array", "items": {"type": "string"}}
      }
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "key", "label", "slot_order"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "key": {"type": "string"},
          "label": {"type": "string"},
          "description": {"type": "string"},
          "slot_order": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          }
        }
      }
    },
    "slots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "key", "label", "dimension", "required", "multi", "value_set"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "key": {"type": "string"},
          "label": {"type": "string"},
          "dimension": {"type": "string"},
          "required": {"type": "boolean"},
          "multi": {"type": "boolean"},
          "value_set": {"type": "string"},
          "description": {"type": "string"}
        }
      }
    },
    "values": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["key", "label"],
          "additionalProperties": false,
          "properties": {
            "key": {"type": "string"},
            "label": {"type": "string"}
          }
        }
      }
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "slots_used", "text"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "description": {"type": "string"},
          "slots_used": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "text": {"type": "string"}
        }
      }
    },
    "generator": {
      "type": "object",
      "required": ["default_template_id", "slot_sequence", "required_slots"],
      "additionalProperties": false,
      "properties": {
        "default_template_id": {"type": "string"},
        "slot_sequence": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "required_slots": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "modes": {"type": "array", "items": {"type": "string"}},
        "copy_behavior": {"type": "string"},
        "empty_value_behavior": {"type": "string"}
      }
    },
    "workflows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "template_id", "values"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "template_id": {"type": "string"},
          "values": {
            "type": "object",
            "additionalProperties": {"type": "string"}
          }
        }
      }
    },
    "heuristics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "description": {"type": "string"},
        "recommendations": {"type": "array"},
        "constraints": {"type": "array"},
        "meta": {"type": "object"}
      }
    }
  }
}
