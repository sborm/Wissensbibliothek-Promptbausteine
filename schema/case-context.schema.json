{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/case-context.schema.json",
  "title": "Case Context Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_meta",
    "case_contexts",
    "context_blocks",
    "dependencies",
    "linked_example_instances"
  ],
  "properties": {
    "case_meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "description",
        "source_note",
        "date_context"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "source_note": {
          "type": "string",
          "minLength": 1
        },
        "date_context": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "case_contexts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "description",
          "meta",
          "shared_blocks"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "meta": {
            "type": "object"
          },
          "shared_blocks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "context_blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "status",
          "content"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "gesichert",
              "abgeleitet",
              "offen_zu_pruefen"
            ]
          },
          "content": {
            "type": "object"
          }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "from",
          "to",
          "type",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "gesichert",
              "abgeleitet",
              "offen_zu_pruefen"
            ]
          }
        }
      }
    },
    "linked_example_instances": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "base_context",
          "focus_blocks",
          "values"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "base_context": {
            "type": "string",
            "minLength": 1
          },
          "focus_blocks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "values": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ]
            }
          }
        }
      }
    }
  }
}